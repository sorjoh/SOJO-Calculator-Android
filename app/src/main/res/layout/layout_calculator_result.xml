<?xml version="1.0" encoding="utf-8"?>
<!-- START: Result frame -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorDisplayBackground">

    <!-- START: Current and previous result -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/Result"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_memory_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/memory_status_text"
                    android:textAlignment="textStart"
                    android:textSize="30sp"
                    android:textColor="@color/colorMemoryStatusText"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ListView
                        android:id="@+id/lv_history_result"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="3"
                        android:text="@string/default_history_result_text"
                        android:textAlignment="textEnd"
                        android:gravity="bottom|end"
                        android:textSize="20sp"
                        android:maxLines="7"
                        android:scrollbars="vertical"
                        android:scrollbarStyle="outsideInset"
                        android:fadeScrollbars="false"
                        android:textColor="@color/colorHistoryResultText"/>

                    <!--
                    <TextView
                        android:id="@+id/tv_history_result"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="3"
                        android:text="@string/default_history_result_text"
                        android:textAlignment="textEnd"
                        android:gravity="bottom|end"
                        android:textSize="20sp"
                        android:maxLines="7"
                        android:scrollbars="vertical"
                        android:scrollbarStyle="outsideInset"
                        android:fadeScrollbars="false"
                        android:textColor="@color/colorHistoryResultText"/>
                    -->

                    <View
                        android:id="@+id/tv_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/colorHistoryResultDivider"/>

                    <TextView
                        android:id="@+id/tv_previous_result"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="@string/default_previous_result_text"
                        android:textAlignment="textEnd"
                        android:gravity="bottom|end"
                        android:textSize="20sp"
                        android:maxLines="1"
                        android:textColor="@color/colorDisplayText"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_current_result"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom|end"
                android:text="@string/default_current_result_text"
                android:textSize="30sp"
                android:maxLines="1"
                android:textColor="@color/colorDisplayText"/>
        </LinearLayout>
    </LinearLayout>
    <!-- END: Current and previous result -->
</LinearLayout>
<!-- END: Result frame -->

