<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <Button style="@style/button"
        android:id="@+id/btn_memory_clear"
        android:text="MC"
        android:background="@color/colorMemoryFunctionBtnBackground"
        android:textColor="@color/colorMemoryFunctionBtnText"/>

    <Button style="@style/button"
        android:id="@+id/btn_memory_recall"
        android:text="MR"
        android:background="@color/colorMemoryFunctionBtnBackground"
        android:textColor="@color/colorMemoryFunctionBtnText"/>

    <Button style="@style/button"
        android:id="@+id/btn_memory_store"
        android:text="MS"
        android:background="@color/colorMemoryFunctionBtnBackground"
        android:textColor="@color/colorMemoryFunctionBtnText"/>

    <Button style="@style/button"
        android:id="@+id/btn_memory_add"
        android:text="M+"
        android:background="@color/colorMemoryFunctionBtnBackground"
        android:textColor="@color/colorMemoryFunctionBtnText"/>

    <Button style="@style/button"
        android:id="@+id/btn_memory_subtract"
        android:text="M-"
        android:background="@color/colorMemoryFunctionBtnBackground"
        android:textColor="@color/colorMemoryFunctionBtnText"/>
</LinearLayout><!-- END: MC MR MS M+ M- -->