<?xml version="1.0" encoding="utf-8"?>
<!-- START: Main frame -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/layout_calculator_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:layout_gravity="top"/>

    <!-- START: Button frame -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:gravity="bottom"
        android:orientation="vertical">

       <include layout="@layout/layout_memory_buttons"
           android:layout_width="match_parent"
           android:layout_height="0dp"
           android:layout_weight="1"
           tools:ignore="NestedWeights" />
       <include layout="@layout/layout_special_operation_buttons"
           android:layout_width="match_parent"
           android:layout_height="0dp"
           android:layout_weight="2"
       />
       <include layout="@layout/layout_number_and_basic_operation_buttons"
           android:layout_width="match_parent"
           android:layout_height="0dp"
           android:layout_weight="4"
       />
    </LinearLayout>
    <!-- END: Button frame -->
</LinearLayout>
<!-- END: Main frame -->